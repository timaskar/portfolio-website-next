{
  "name": "remotion-eye-mascot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "studio": "remotion studio",
    "still": "remotion still EyeMascot --frame=126 --scale=0.5 out/eye-mascot-warning-frame.png",
    "render:webm": "remotion render EyeMascot out/eye-mascot-transparent.webm --image-format=png --pixel-format=yuva420p --codec=vp9",
    "render:loader": "remotion render EyeMascot ../assets/loader-intro.mp4 --codec=h264 --pixel-format=yuv420p --crf=18"
  },
  "dependencies": {
    "@remotion/cli": "4.0.468",
    "remotion": "4.0.468",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "typescript": "5.9.2"
  }
}
